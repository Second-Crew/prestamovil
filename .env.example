# ─── Credenciales Libro Azul ────────────────────────────────────────────────
# Obtén estas credenciales en tu cuenta de Guía EBC / Libro Azul
LIBROAZUL_USER=tu_usuario_aqui
LIBROAZUL_PASS=tu_contrasena_aqui

# ─── Porcentaje de Préstamo ──────────────────────────────────────────────────
# Qué fracción del valor de mercado ofreces como préstamo.
# 0.70 = 70%, 0.65 = 65%, 0.60 = 60%
# Para cambiarlo: actualiza este valor en Vercel → Settings → Environment Variables
LOAN_PERCENTAGE=0.70
